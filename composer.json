{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "bacon/bacon-qr-code": "^3.0",
        "filament/filament": "^5.0",
        "laravel/cashier": "^16.4",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.45",
        "laravel/pulse": "^1.7",
        "laravel/tinker": "^2.10.1",
        "livewire/flux": "^2.13",
        "livewire/volt": "^1.10",
        "pragmarx/google2fa-laravel": "^2.3",
        "saloonphp/laravel-plugin": "^3.9",
        "saloonphp/rate-limit-plugin": "^2.4",
        "saloonphp/saloon": "^3.15",
        "spatie/laravel-csp": "^3.23",
        "spatie/laravel-permission": "^7.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": "composer install && cp .env.example .env && php artisan key:generate && npm install && php artisan migrate",
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently --names=server,horizon,pulse,logs,vite \"php artisan serve\" \"php artisan horizon\" \"php artisan pulse:work\" \"php artisan pail\" \"npm run dev\""
        ],
        "test": "./vendor/bin/pest",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
