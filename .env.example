# Environment variable reference — documents all env vars, types, and sensitivity.
#
# Platform API credentials (ActiveCampaign, ExpertSender, Maropost, Voluum)
# are entered by users through the UI and stored encrypted in the database.
# They are NOT environment variables.

# -- Application --

APP_NAME=Revat
APP_ENV=local
# Laravel encryption key, generated via `php artisan key:generate`
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# -- Logging --

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=
LOG_LEVEL=debug

# -- Database --

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=revat-v4
DB_USERNAME=revat-v4
DB_PASSWORD=

# -- Session --

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
# Session cookie name — pinned to prevent L13 delimiter change
SESSION_COOKIE=revat-session

# -- Services --

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# Cache key prefix — pinned to prevent L13 delimiter change
CACHE_PREFIX=revat_v4_cache_

MEMCACHED_HOST=127.0.0.1

# -- Redis --

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_PREFIX=revat_v4_

# -- Horizon --

HORIZON_PREFIX=revat_v4_horizon:

# -- Mail --

MAIL_MAILER=log
MAIL_SCHEME=
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@revat.com"
MAIL_FROM_NAME="${APP_NAME}"

# -- Resend --

# Resend API key for transactional email delivery
RESEND_API_KEY=

# -- AWS --

# AWS IAM access key for S3/SES
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -- Pulse (monitoring) --

PULSE_INGEST_DRIVER=redis
PULSE_ENABLED=true

# -- Admin --

# Comma-separated list of admin email addresses
ADMIN_EMAILS=

# -- Stripe / Billing --

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=usd

# -- Vite --

VITE_APP_NAME="${APP_NAME}"
